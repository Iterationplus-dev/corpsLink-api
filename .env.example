APP_NAME=CorpsLink
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file


BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=exam_app
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=zeptomail
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@corpslink.ng"
MAIL_FROM_NAME="${APP_NAME}"

ZEPTOMAIL_URL=
ZEPTOMAIL_TOKEN=


TERMII_URL=https://v3.api.termii.com
TERMII_API_KEY=
TERMII_SENDER_ID=CorpsLink

PAYSTACK_URL=https://api.paystack.co
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Where Paystack redirects the browser after a hosted checkout completes.
# Defaults to {APP_URL}/payments/callback if unset.
PAYSTACK_CALLBACK_URL=

FLUTTERWAVE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
# Shared secret configured in the Flutterwave dashboard under Settings ›
# Webhooks › Secret Hash — NOT a URL. Was pointing at a URL before, which
# meant webhook signature validation silently rejected every real webhook.
FLUTTERWAVE_WEBHOOK_HASH=
# Where Flutterwave redirects the browser after a hosted checkout completes.
# Defaults to {APP_URL}/payments/callback if unset.
FLUTTERWAVE_REDIRECT_URL=

# Merchant contract identifier from the Monnify dashboard — required on
# every transaction, no default possible.
# Where Monnify redirects the browser after a hosted checkout completes.
# Defaults to {APP_URL}/payments/callback if unset.

#Alternate
MONNIFY_URL=
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
# Merchant contract identifier from the Monnify dashboard — required on
# every transaction, no default possible.
MONNIFY_CONTRACT_CODE=
# Where Monnify redirects the browser after a hosted checkout completes.
# Defaults to {APP_URL}/payments/callback if unset.
MONNIFY_REDIRECT_URL=

# Path to a Firebase service-account JSON file. Push notifications are
# inert (logged, not sent) until this is set.
FIREBASE_CREDENTIALS=
FIREBASE_PROJECT=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
